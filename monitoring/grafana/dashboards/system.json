{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Utilisation CPU (process Python)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{service=\"api\"}[5m]) * 100",
          "legendFormat": "API CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        },
        "overrides": []
      }
    },
    {
      "title": "Mémoire résidente (RSS)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{service=\"api\"}",
          "legendFormat": "API RSS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 15 }
        },
        "overrides": []
      }
    },
    {
      "title": "File descriptors ouverts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_open_fds{service=\"api\"}",
          "legendFormat": "Open FDs"
        },
        {
          "expr": "process_max_fds{service=\"api\"}",
          "legendFormat": "Max FDs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 5 }
        },
        "overrides": []
      }
    },
    {
      "title": "Connexions DB pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sqlalchemy_pool_checked_out{service=\"api\"}",
          "legendFormat": "Checked out"
        },
        {
          "expr": "sqlalchemy_pool_size{service=\"api\"}",
          "legendFormat": "Pool size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      }
    },
    {
      "title": "Tous les logs (recherche libre)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\".+\"} | json",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["gegm", "system"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "GEGM — System",
  "uid": "gegm-system"
}
