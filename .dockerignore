# Exclusions pour les builds Docker — minimise la taille du contexte.

# Environnements virtuels Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Frontend
frontend/node_modules/
frontend/dist/
frontend/src-tauri/target/
frontend/src-tauri/gen/

# Git
.git/
.gitignore
.gitattributes

# IDE
.vscode/
.idea/
.claude/

# Tests et caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Docker
docker-compose*.yml
*.Dockerfile
Dockerfile*
.dockerignore

# Secrets et config locale
.env
.env.local
.env.production
.env.staging

# Monitoring (pas nécessaire dans l'image backend)
monitoring/

# RunPod worker (image séparée)
runpod-worker/

# Docs
*.md
!README.md

# OS
.DS_Store
