# GEGM_Upscaler — Variables d'environnement backend
# Copier vers .env : cp .env.example .env
# ⚠️  NE JAMAIS COMMITER .env (il contient les secrets prod)
#
# Chaque variable est lue par backend/app/core/config.py (pydantic-settings).
# Les valeurs ci-dessous sont les defauts — retire le commentaire pour surcharger.

# ── Application ─────────────────────────────────────────────────
APP_ENV=development                      # development | staging | production

# CORS (liste JSON si surcharge, sinon defaut du code)
# CORS_ORIGINS=["http://localhost:5173","https://upscaler.gegmgroup.com"]

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://upscaler:upscaler@localhost:5432/upscaler

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Storage ─────────────────────────────────────────────────────
STORAGE_BACKEND=local                    # local | s3
LOCAL_STORAGE_PATH=/data

# S3 (AWS / OVH / R2 / MinIO) — actifs si STORAGE_BACKEND=s3
# S3_BUCKET=gegm-upscaler-prod
# S3_ENDPOINT_URL=https://s3.gra.io.cloud.ovh.net
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=auto                         # auto | gra | sbg | us-east-1 | ...

# ── Auth ────────────────────────────────────────────────────────
AUTH_BACKEND=static_token                # static_token | oidc
DEV_AUTH_TOKEN=dev-secret-token-change-me

# OIDC (Keycloak / Google Workspace / Entra ID) — actifs si AUTH_BACKEND=oidc
# OIDC_ISSUER=https://keycloak.example.com/realms/gegm
# OIDC_CLIENT_ID=gegm-upscaler
# OIDC_CLIENT_SECRET=

# ── GPU ─────────────────────────────────────────────────────────
UPSCALE_MODEL=drct-l                     # drct-l | hat-l (fallback)
COREML_MODEL_DIR=models                  # Repertoire des .mlpackage pour l'inference locale

# RunPod Serverless (obligatoire pour les images >5 MP)
# Cree l'endpoint sur https://www.runpod.io/console/serverless/
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Stockage des outputs RunPod (bucket S3-compatible)
# Le handler RunPod upload les images upscalees sur ce bucket pour contourner
# la limite de ~20 MB de payload /status. Configure aussi dans l'UI RunPod en
# variables d'env du endpoint (STORAGE_BACKEND, S3_ENDPOINT_URL, etc.).
# - Dev : Cloudflare R2 (gratuit jusqu'a 10 GB, pas d'egress)
# - Prod : bucket OVH Object Storage (meme format S3-compatible)
# S3_OUTPUT_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# S3_OUTPUT_BUCKET=gegm-upscaler-outputs-dev
# S3_OUTPUT_ACCESS_KEY=
# S3_OUTPUT_SECRET_KEY=
# S3_OUTPUT_REGION=auto

# ── Monitoring ──────────────────────────────────────────────────
# Sentry : DSN projet — instance self-hosted GEGM sur errors.vixns.net
# (instance interne, pas le SaaS sentry.io). Format du DSN :
# https://<key>@errors.vixns.net/<project-id>
# En prod, ce DSN est lu depuis Vault via SECRETS_BACKEND=vault.
# SENTRY_DSN=https://<key>@errors.vixns.net/<project-id>

# ── Frontend embarque ───────────────────────────────────────────
# Chemin absolu vers le dossier dist/ du frontend Vite. Quand
# renseigne et que le dossier existe, FastAPI sert le SPA sur toutes
# les routes non-API (fallback index.html pour les deep links React
# Router).
# - En dev local : laisser vide → Vite tourne sur :5173.
# - En prod Docker : positionne a /app/frontend/dist par le Dockerfile
#   (3 stages : python-builder + frontend-builder + runtime).
# FRONTEND_DIST=

# ── Secrets (prod) ──────────────────────────────────────────────
SECRETS_BACKEND=env                      # env | infisical | vault

# Infisical SaaS
# INFISICAL_TOKEN=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=prod
# INFISICAL_API_URL=https://app.infisical.com/api

# HashiCorp Vault (KV v2 par defaut)
# VAULT_ADDR=https://vault.internal.gegm.com
# VAULT_TOKEN=
# VAULT_MOUNT_PATH=secret
# VAULT_KV_VERSION=2                     # 1 | 2
