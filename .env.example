# GEGM_Upscaler — Variables d'environnement
# Copier vers .env : cp .env.example .env
# ⚠️  NE JAMAIS COMMITER .env

APP_ENV=development

# Database
DATABASE_URL=postgresql+asyncpg://upscaler:upscaler@localhost:5432/upscaler

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/data
# S3_BUCKET=
# S3_ENDPOINT_URL=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Auth
AUTH_BACKEND=static_token
DEV_AUTH_TOKEN=dev-secret-token-change-me
# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# GPU Cloud
UPSCALE_MODEL=drct-l
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# Monitoring
# SENTRY_DSN=

# Secrets (prod)
SECRETS_BACKEND=env
# INFISICAL_TOKEN=
# VAULT_ADDR=
# VAULT_TOKEN=
