# GEGM_Upscaler — Variables d'environnement backend
# Copier vers .env : cp .env.example .env
# ⚠️  NE JAMAIS COMMITER .env (il contient les secrets prod)
#
# Chaque variable est lue par backend/app/core/config.py (pydantic-settings).
# Les valeurs ci-dessous sont les defauts — retire le commentaire pour surcharger.

# ── Application ─────────────────────────────────────────────────
APP_ENV=development                      # development | staging | production

# CORS (liste JSON si surcharge, sinon defaut du code)
# CORS_ORIGINS=["http://localhost:5173","https://upscaler.gegmgroup.com"]

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://upscaler:upscaler@localhost:5432/upscaler

# ── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Storage ─────────────────────────────────────────────────────
STORAGE_BACKEND=local                    # local | s3
LOCAL_STORAGE_PATH=/data

# S3 (AWS / OVH / R2 / MinIO) — actifs si STORAGE_BACKEND=s3
# S3_BUCKET=gegm-upscaler-prod
# S3_ENDPOINT_URL=https://s3.gra.io.cloud.ovh.net
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=auto                         # auto | gra | sbg | us-east-1 | ...

# ── Auth ────────────────────────────────────────────────────────
AUTH_BACKEND=static_token                # static_token | oidc
DEV_AUTH_TOKEN=dev-secret-token-change-me

# OIDC (Keycloak / Google Workspace / Entra ID) — actifs si AUTH_BACKEND=oidc
# OIDC_ISSUER=https://keycloak.example.com/realms/gegm
# OIDC_CLIENT_ID=gegm-upscaler
# OIDC_CLIENT_SECRET=

# ── GPU ─────────────────────────────────────────────────────────
UPSCALE_MODEL=drct-l                     # legacy Core ML local uniquement
# Le routage cloud RunPod est dérivé du scale_factor côté backend
# (x4 → DRCT-L, x2 → HAT-L). Cette variable ne contrôle que le chemin
# de conversion Core ML (désactivé en v2 cloud-only).
COREML_MODEL_DIR=models                  # Repertoire des .mlpackage pour l'inference locale

# RunPod Serverless (obligatoire pour les images >5 MP)
# Cree l'endpoint sur https://www.runpod.io/console/serverless/
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=

# ── Limites upload / jobs GPU ───────────────────────────────────
# Taille max d'un fichier image uploade (Mo). Coherent avec la limite
# memoire du pod API en prod (le fichier transite en RAM).
# MAX_UPLOAD_SIZE_MB=300
# Plafond megapixels de l'image source — borne par le budget temps GPU
# (duree estimee 60+50xMP s) et la RAM du worker RunPod.
# MAX_INPUT_MEGAPIXELS=64
# Plafond du timeout dynamique d'un job GPU (s). Doit rester <= a
# l'Execution Timeout configure sur l'endpoint RunPod.
# GPU_JOB_TIMEOUT_MAX_S=3600
# Achemine l'input au worker GPU par URL S3 presignee (gros fichiers).
# Mettre a false si le worker deploye ne supporte pas encore image_url.
# GPU_INPUT_URL_ENABLED=true

# Stockage des outputs RunPod (bucket S3-compatible)
# Le handler RunPod upload les images upscalees sur ce bucket pour contourner
# la limite de ~20 MB de payload /status. Configure aussi dans l'UI RunPod en
# variables d'env du endpoint (STORAGE_BACKEND, S3_ENDPOINT_URL, etc.).
# - Dev : Cloudflare R2 (gratuit jusqu'a 10 GB, pas d'egress)
# - Prod : bucket OVH Object Storage (meme format S3-compatible)
# S3_OUTPUT_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# S3_OUTPUT_BUCKET=gegm-upscaler-outputs-dev
# S3_OUTPUT_ACCESS_KEY=
# S3_OUTPUT_SECRET_KEY=
# S3_OUTPUT_REGION=auto

# ── Monitoring ──────────────────────────────────────────────────
# Sentry : DSN projet — instance self-hosted GEGM sur errors.vixns.net
# (instance interne, pas le SaaS sentry.io). Format du DSN :
# https://<key>@errors.vixns.net/<project-id>
# En prod, ce DSN est lu depuis Vault via SECRETS_BACKEND=vault.
# SENTRY_DSN=https://<key>@errors.vixns.net/<project-id>
#
# Frontend (React/Tauri) — DSN distinct du backend, injecté au build-time.
# Pas lu depuis le .env runtime mais depuis les build-args Docker /
# secrets GitHub (FRONTEND_SENTRY_DSN). Laissé vide en dev = no-op.
# VITE_SENTRY_DSN=https://<key>@errors.vixns.net/<project-id>
# VITE_SENTRY_ENVIRONMENT=production          # production | staging | production-tauri
# VITE_APP_VERSION=v0.1.0                     # auto-injecté par CI (tag git)

# OpenTelemetry — traces distribuées FastAPI → Celery → RunPod.
# Endpoint vide = OTel désactivé (no-op, pas d'overhead réseau). En prod
# GEGM : pointer sur l'OTel collector interne ou directement sur
# VictoriaMetrics (gRPC OTLP ingest).
# OTEL_SERVICE_NAME=gegm-upscaler-api          # "-worker" côté Celery (auto-override)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.monitoring:4317
# OTEL_EXPORTER_OTLP_INSECURE=true             # false si collector via TLS
# OTEL_TRACES_SAMPLER_RATIO=0.1                # 10% — ajuster selon volume

# ── Frontend embarque ───────────────────────────────────────────
# Chemin absolu vers le dossier dist/ du frontend Vite. Quand
# renseigne et que le dossier existe, FastAPI sert le SPA sur toutes
# les routes non-API (fallback index.html pour les deep links React
# Router).
# - En dev local : laisser vide → Vite tourne sur :5173.
# - En prod Docker : positionne a /app/frontend/dist par le Dockerfile
#   (3 stages : python-builder + frontend-builder + runtime).
# FRONTEND_DIST=

# ── Frontend Vite (build-time uniquement) ──────────────────────
# Les variables ci-dessous sont lues par Vite au build (`npm run build`
# ou `npm run tauri:build`), pas au runtime. Elles sont substituees
# dans le bundle JS et donc figees par image. En CI :
# - `docker.yml` → injecte VITE_*_PROD via --build-arg sur l'image backend
# - `release-tauri.yml` → injecte VITE_*_PROD via env vars du job
# En dev local : Vite lit `frontend/.env` (a creer a partir de ce
# fichier en filtrant les VITE_*) ou les valeurs par defaut codees
# dans `frontend/src/lib/auth.ts` et `frontend/src/lib/constants.ts`.
#
# VITE_API_BASE=                                # Defaut: "/api". Mettre l'URL absolue du backend pour Tauri prod (https://upscaler.gegmgroup.com/api).
# VITE_AUTH_MODE=dev                            # dev | oidc — dev = static token, oidc = flow PKCE Keycloak
# VITE_DEV_TOKEN=dev-secret-token-change-me     # Token statique mode dev (matche DEV_AUTH_TOKEN backend)
# VITE_OIDC_ISSUER=                             # URL realm Keycloak (ex. https://keycloak.gegmgroup.com/realms/gegm)
# VITE_OIDC_CLIENT_ID=gegm-upscaler             # Client ID public Keycloak (PKCE = pas de secret)
# VITE_OIDC_REDIRECT_URI=                       # Defaut: ${origin}/auth/callback. Surcharger uniquement si redirect custom.

# ── Secrets (prod) ──────────────────────────────────────────────
SECRETS_BACKEND=env                      # env | infisical | vault

# Infisical SaaS
# INFISICAL_TOKEN=
# INFISICAL_PROJECT_ID=
# INFISICAL_ENVIRONMENT=prod
# INFISICAL_API_URL=https://app.infisical.com/api

# HashiCorp Vault (KV v2 par defaut)
# VAULT_ADDR=https://vault.internal.gegm.com
# VAULT_TOKEN=
# VAULT_MOUNT_PATH=secret
# VAULT_KV_VERSION=2                     # 1 | 2
